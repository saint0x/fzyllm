use core.time;
use core.fs;
use core.http;
use core.proc;
use core.mem;
use core.thread;

mod api;
mod model;
mod services;
mod runtime;
mod cli;
mod tests;

fn main() -> i32 {
    requires true

    log.info("anthropic_smoke main starting", log.fields2("component", "main", "phase", "boot"))
    model.preflight()
    log.info("anthropic_smoke model preflight complete", log.fields2("component", "main", "phase", "model_preflight"))
    cli.boot()
    log.info("anthropic_smoke cli boot complete", log.fields2("component", "main", "phase", "cli_boot"))
    services.boot_all()
    log.info("anthropic_smoke services boot complete", log.fields2("component", "main", "phase", "services_boot"))
    runtime.start()
    log.info("anthropic_smoke runtime start complete", log.fields2("component", "main", "phase", "runtime_start"))
    api.touch()
    log.info("anthropic_smoke api touch complete", log.fields2("component", "main", "phase", "api_touch"))
    log.info("anthropic_smoke entering serve_forever", log.fields2("component", "main", "phase", "serve_forever"))
    services.web.serve_forever()

    ensures true
    return 0
}
