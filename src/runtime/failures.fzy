enum FailureClass {
    SpawnFailure,
    Timeout,
    NonzeroExit,
    MalformedOutput,
}

fn failure_class_code(class: FailureClass) -> i32 {
    match class {
        FailureClass::SpawnFailure => return 11,
        FailureClass::Timeout => return 12,
        FailureClass::NonzeroExit => return 13,
        _ => return 14,
    }
    return 14
}

fn failure_class_label(class: FailureClass) -> str {
    match class {
        FailureClass::SpawnFailure => return "spawn_failure",
        FailureClass::Timeout => return "timeout",
        FailureClass::NonzeroExit => return "nonzero_exit",
        _ => return "malformed_output",
    }
    return "malformed_output"
}

fn classify_spawn_failure() -> FailureClass {
    return FailureClass::SpawnFailure
}

fn classify_timeout() -> FailureClass {
    return FailureClass::Timeout
}

fn classify_nonzero_exit() -> FailureClass {
    return FailureClass::NonzeroExit
}

fn classify_malformed_output() -> FailureClass {
    return FailureClass::MalformedOutput
}
