use core.proc;

fn configure_limits() -> i32 {
    log.info("runtime.supervisor configure_limits", log.fields2("component", "runtime.supervisor", "phase", "configure_limits"))
    process.exec_timeout(500)
    return 0
}

fn begin_shutdown() -> i32 {
    runtime.sandbox.deny_tool_scope()
    services.http.graceful_stop()
    runtime.recovery.recover_inflight_jobs()
    process.exec_timeout(500)
    return 0
}

fn run_forever() -> i32 {
    log.info("runtime.supervisor started", log.fields2("component", "runtime.supervisor", "phase", "loop_start"))
    loop {
        runtime.events.emit_health_tick()
        process.exec_timeout(200)
    }
}
