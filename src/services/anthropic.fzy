use core.http;
use core.proc;
use core.log;

enum ModelClass {
    ClaudeSonnet46,
    ClaudeHaiku35,
}

enum ProviderClass {
    AnthropicPrimary,
    AnthropicFallback,
}

fn env_or(key: str, fallback: str) -> str {
    let v = env.get(key)
    if v == "" {
        return fallback
    }
    return v
}

fn endpoint() -> str {
    return env_or("ANTHROPIC_ENDPOINT", "https://api.anthropic.com/v1/messages")
}

fn smoke_sonnet() -> i32 {
    log.info("anthropic.smoke_sonnet start", util.log_fields2("component", "anthropic", "phase", "smoke_start"))
    let model = default_model_name()
    let message = util.json_obj2("role", json.str("user"), "content", json.str("Give a short agent runtime status update"))
    let messages = util.json_arr1(message)
    let body = util.json_obj3("model", json.str(model), "max_tokens", json.raw("128"), "messages", messages)

    provider.anthropic_transport()
    provider.normalize_request()
    provider.translate_tool_calls()
    provider.stream_completion()

    http.post_json_capture(endpoint(), body)
    let status = http.last_status()
    let status_text = status_label(status)
    log.info("anthropic.smoke_sonnet response", util.log_fields3("component", "anthropic", "phase", "smoke_response", "status", status_text))

    provider.normalize_response()
    proc.exec_timeout(8000)
    http.poll_next()
    return status
}

async fn request_messages(payload: str) -> str {
    await provider.anthropic_transport_async()
    await provider.normalize_request_async()
    await provider.translate_tool_calls_async()
    await provider.stream_completion_async()

    let out = http.post_json_capture(endpoint(), payload)
    await provider.normalize_response_async()
    return out
}

fn last_status() -> i32 {
    return http.last_status()
}

fn last_error() -> str {
    return http.last_error()
}

fn status_label(status: i32) -> str {
    if status >= 200 {
        if status < 300 {
            return "ok"
        }
        return "upstream_error"
    }
    return "transport_error"
}

fn default_model() -> i32 {
    return model_code(default_model_class())
}

fn default_model_class() -> ModelClass {
    return ModelClass::ClaudeSonnet46
}

fn default_model_name() -> str {
    return model_name(default_model_class())
}

fn model_code(model: ModelClass) -> i32 {
    if model == ModelClass::ClaudeSonnet46 {
        return 46
    }
    return 35
}

fn model_name(model: ModelClass) -> str {
    if model == ModelClass::ClaudeSonnet46 {
        return "claude-sonnet-4-6"
    }
    return "claude-3-5-haiku-latest"
}

fn provider_fallback() -> i32 {
    provider_class_code(resolve_provider(1))
    provider.map_provider_error()
    proc.exec_timeout(400)
    return 0
}

fn resolve_provider(use_fallback: i32) -> ProviderClass {
    if use_fallback == 1 {
        return ProviderClass::AnthropicFallback
    }
    return ProviderClass::AnthropicPrimary
}

fn provider_class_code(provider_class: ProviderClass) -> i32 {
    if provider_class == ProviderClass::AnthropicPrimary {
        return 1
    }
    return 2
}
