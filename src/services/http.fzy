use core.net;
use core.proc;

fn configure_server() -> i32 {
    env.get("AGENT_HOST")
    env.get("AGENT_PORT")
    env.get("AGENT_WORKERS")
    return 0
}

fn start_server() -> i32 {
    log.info("http.start_server", "{\"component\":\"http\",\"phase\":\"start_server\"}")
    web.start_listener()
    return 0
}

fn graceful_stop() -> i32 {
    checkpoint()
    return 0
}

fn listen_public() -> i32 {
    let listener = try net.bind() catch net.bind()
    net.listen(listener)
    return 0
}

fn accept_once() -> i32 {
    let conn = try net.accept() catch net.accept()
    defer close(conn)
    net.read(conn)
    net.write(conn, 200, "ok")
    return 0
}

fn accept_and_dispatch() -> i32 {
    web.accept_and_process()
    return 0
}

fn post_sessions() -> i32 {
    security.auth_middleware()
    security.rate_limit()
    sessions.create_session()
    return 0
}

fn get_session() -> i32 {
    security.auth_middleware()
    security.rate_limit()
    sessions.get_session()
    return 0
}

fn post_session_messages() -> i32 {
    security.auth_middleware()
    security.rate_limit()
    sessions.post_message()
    return 0
}

fn get_tools() -> i32 {
    security.auth_middleware()
    security.rate_limit()
    registry.list_tools()
    return 0
}

fn post_tools() -> i32 {
    security.auth_middleware()
    security.rate_limit()
    registry.register_tool()
    return 0
}

fn delete_tool() -> i32 {
    security.auth_middleware()
    security.rate_limit()
    registry.unregister_tool()
    return 0
}

fn post_tool_run() -> i32 {
    security.auth_middleware()
    security.rate_limit()
    tools.run_parallel()
    tools.classify_failure()
    persistence.save_tool_run()
    return 0
}

fn get_run() -> i32 {
    security.auth_middleware()
    security.rate_limit()
    persistence.load_session()
    return 0
}

fn route_sessions() -> i32 {
    post_sessions()
    get_session()
    return 0
}

fn route_messages() -> i32 {
    post_session_messages()
    return 0
}

fn route_tools() -> i32 {
    get_tools()
    post_tools()
    delete_tool()
    return 0
}

fn route_runs() -> i32 {
    post_tool_run()
    get_run()
    return 0
}

fn handle_sessions(conn: i32) -> i32 {
    log.info("http.handle_sessions", "{\"component\":\"http\",\"handler\":\"sessions_create\"}")
    post_sessions()
    let body = json.object4("status", json.str("ok"), "event", json.str("session_created"), "session_id", json.str("demo"), "provider", json.str("anthropic"))
    net.write_json(conn, 200, body)
    return 0
}

fn handle_session_get(conn: i32) -> i32 {
    log.info("http.handle_session_get", "{\"component\":\"http\",\"handler\":\"session_get\"}")
    get_session()
    let session_id = net.param(conn, "id")
    let state = model.types.active_session_state_label()
    let body = json.object4("status", json.str("ok"), "event", json.str("session_loaded"), "session_id", json.str(session_id), "state", json.str(state))
    net.write_json(conn, 200, body)
    return 0
}

fn handle_messages(conn: i32) -> i32 {
    log.info("http.handle_messages start", "{\"component\":\"http\",\"handler\":\"messages_post\",\"phase\":\"start\"}")
    post_session_messages()
    safety.filter_prompt()
    safety.filter_tool_response()
    safety.decide_policy()

    let session_id = net.param(conn, "id")
    let raw_body = net.body(conn)
    let decoded = json.parse(raw_body)
    let message = json.get_str(decoded, "message")

    let tool_logs = list.new()

    let ls_handle = process.runv("ls", "[\"-1\",\"/Users/deepsaint/Desktop\"]", "{}", "")
    process.wait(ls_handle, 5000)
    list.push(tool_logs, "ls -1 /Users/deepsaint/Desktop")

    let rg_handle = process.runv("rg", "[\"-n\",\"--no-heading\",\"--max-count\",\"20\",\"-g\",\"*.md\",\"FZY\",\"/Users/deepsaint/Desktop\"]", "{}", "")
    process.wait(rg_handle, 8000)
    list.push(tool_logs, "rg -n --no-heading --max-count 20 -g *.md FZY /Users/deepsaint/Desktop")

    let touch_handle = process.runv("touch", "[\"/Users/deepsaint/Desktop/test_from_agent.txt\"]", "{}", "")
    process.wait(touch_handle, 2000)
    list.push(tool_logs, "touch /Users/deepsaint/Desktop/test_from_agent.txt")

    let api_key = env.get("ANTHROPIC_API_KEY")
    let endpoint = "https://api.anthropic.com/v1/messages"
    let system_prompt = "You are DeepSaint's personal local agent with local tool access. Answer the user's question directly first. Use tool outputs only when relevant, and do not default to generic tool summaries."
    let tool_context = "Executed tools: ls on Desktop, rg for FZY in Desktop markdown files, and touch on /Users/deepsaint/Desktop/test_from_agent.txt."
    let user_context = str.concat4("USER_QUERY:\n", message, "\n\nTool outputs (optional context):\n", tool_context)
    let user_msg = json.object2("role", json.str("user"), "content", json.str(user_context))
    let messages = json.array1(user_msg)
    let payload = json.object4("model", json.str("claude-sonnet-4-6"), "max_tokens", json.raw("300"), "system", json.str(system_prompt), "messages", messages)

    http.header("x-api-key", api_key)
    http.header("anthropic-version", "2023-06-01")
    http.header("content-type", "application/json")
    let out = http.post_json_capture(endpoint, payload)
    let status = http.last_status()
    let transport_error = http.last_error()
    log.info("http.handle_messages anthropic response", "{\"component\":\"http\",\"handler\":\"messages_post\",\"phase\":\"response\"}")
    let tool_logs_payload = json.from_list(tool_logs)
    let provider_payload = json.object3("provider", json.str("anthropic"), "response", json.raw(out), "tool_logs", json.raw(tool_logs_payload))
    if status >= 200 {
        if status < 300 {
            log.info("http.handle_messages success", "{\"component\":\"http\",\"handler\":\"messages_post\",\"phase\":\"success\"}")
            let body = json.object3("status", json.str("ok"), "session_id", json.str(session_id), "data", provider_payload)
            net.write_json(conn, 200, body)
        } else {
            log.warn("http.handle_messages upstream_non_2xx", "{\"component\":\"http\",\"handler\":\"messages_post\",\"phase\":\"upstream_non_2xx\"}")
            let body = json.object3("status", json.str("error"), "session_id", json.str(session_id), "data", provider_payload)
            net.write_json(conn, 502, body)
        }
    } else {
        log.error("http.handle_messages invalid_status", "{\"component\":\"http\",\"handler\":\"messages_post\",\"phase\":\"invalid_status\"}")
        let body = json.object4("status", json.str("error"), "message", json.str("anthropic_invalid_status"), "raw_response", json.str(out), "transport_error", json.str(transport_error))
        net.write_json(conn, 502, body)
    }
    return 0
}

fn handle_tools_register(conn: i32) -> i32 {
    log.info("http.handle_tools_register", "{\"component\":\"http\",\"handler\":\"tools_register\"}")
    post_tools()
    let body = json.object4("status", json.str("ok"), "event", json.str("tool_registered"), "tool_id", json.str("desktop_grep"), "exec_mode", json.str("background"))
    net.write_json(conn, 200, body)
    return 0
}

fn handle_tools_list(conn: i32) -> i32 {
    log.info("http.handle_tools_list", "{\"component\":\"http\",\"handler\":\"tools_list\"}")
    get_tools()
    let body = "{\"status\":\"ok\",\"tools\":[{\"id\":\"desktop_grep\",\"kind\":\"process\",\"health\":\"ready\"}]}"
    net.write_json(conn, 200, body)
    return 0
}

fn handle_tools_delete(conn: i32) -> i32 {
    log.info("http.handle_tools_delete", "{\"component\":\"http\",\"handler\":\"tools_delete\"}")
    delete_tool()
    let tool_id = net.param(conn, "id")
    let body = json.object3("status", json.str("ok"), "event", json.str("tool_deleted"), "tool_id", json.str(tool_id))
    net.write_json(conn, 200, body)
    return 0
}

fn handle_tools_run(conn: i32) -> i32 {
    log.info("http.handle_tools_run start", "{\"component\":\"http\",\"handler\":\"tools_run\",\"phase\":\"start\"}")
    post_tool_run()
    let tool_id = net.param(conn, "id")
    process.exec_timeout(30000)
    let handle = process.runv("rg", "[\"-n\",\"--no-heading\",\"--max-count\",\"1\",\"-g\",\"*.md\",\"FZY\",\"/Users/deepsaint/Desktop\"]", "{}", "")
    process.wait(handle, 30000)
    let code = process.exit_code(handle)
    if code == 0 {
        log.info("http.handle_tools_run success", "{\"component\":\"http\",\"handler\":\"tools_run\",\"phase\":\"success\"}")
        let out = process.stdout(handle)
        let body = json.object4("status", json.str("ok"), "tool_id", json.str(tool_id), "result", json.str(out), "run_id", json.str(tool_id))
        net.write_json(conn, 200, body)
    } else {
        log.warn("http.handle_tools_run nonzero_exit", "{\"component\":\"http\",\"handler\":\"tools_run\",\"phase\":\"nonzero_exit\"}")
        let err = process.stderr(handle)
        let failure = tools.failure_class_label(code)
        let body = json.object4("status", json.str("error"), "tool_id", json.str(tool_id), "failure_class", json.str(failure), "stderr", json.str(err))
        net.write_json(conn, 500, body)
    }
    return 0
}

fn handle_runs(conn: i32) -> i32 {
    log.info("http.handle_runs", "{\"component\":\"http\",\"handler\":\"runs_get\"}")
    get_run()
    let run_id = net.param(conn, "id")
    let run_state = model.types.completed_run_state_label()
    let body = json.object4("status", json.str("ok"), "run_id", json.str(run_id), "state", json.str(run_state), "tool_id", json.str("desktop_grep"))
    net.write_json(conn, 200, body)
    return 0
}

fn handle_health(conn: i32) -> i32 {
    log.info("http.handle_health", "{\"component\":\"http\",\"handler\":\"health\"}")
    let model_name = anthropic.default_model_name()
    let body = json.object4("status", json.str("ok"), "service", json.str("agent_runtime"), "provider", json.str("anthropic"), "model", json.str(model_name))
    net.write_json(conn, 200, body)
    return 0
}
