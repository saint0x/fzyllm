mod store;
mod http;
mod web;
mod anthropic;
mod provider;
mod registry;
mod tools;
mod sessions;
mod telemetry;
mod security;
mod openapi;
mod persistence;
mod chaos;
mod safety;
use core.log;
use registry.list_tools as list_tools_alias;
pub use telemetry.boot_metrics;

fn boot_all() -> i32 {
    log.info("services.boot_all begin", util.log_fields2("component", "services", "phase", "boot_begin"))
    store.init()
    web.boot()
    sessions.boot()
    registry.load_builtin()
    registry.update_tool()
    registry.get_tool()
    registry.list_tools()
    registry.refresh_runtime()
    registry.heartbeat()
    registry.evict_stale()
    registry.planner_hints()
    registry.record_invocation_decision()
    runtime.events.emit_registry_update()

    tools.boot_runner()
    telemetry.boot_metrics()
    runtime.events.emit_health_tick()

    security.auth_middleware()
    security.rate_limit()
    safety.filter_prompt()
    safety.filter_tool_response()
    safety.decide_policy()

    openapi.export_spec()
    openapi.validate_schema()

    persistence.load_session()

    chaos.inject_slow_tool()
    chaos.inject_malformed_payload()
    chaos.inject_provider_latency()
    log.info("services.boot_all complete", util.log_fields2("component", "services", "phase", "boot_complete"))
    return 0
}
