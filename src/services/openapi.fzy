use core.fs;

fn openapi_path() -> str {
    return "/tmp/anthropic_smoke/openapi.json"
}

fn export_spec() -> i32 {
    fs.mkdir("/tmp/anthropic_smoke")
    let paths = util.json_obj4(
        "sessions", json.str("POST /sessions, GET /sessions/:id"),
        "messages", json.str("POST /sessions/:id/messages"),
        "tools", json.str("GET/POST/DELETE /tools"),
        "runs", json.str("POST /tools/:id/run, GET /runs/:id"),
    )
    let spec = util.json_obj3("openapi", json.str("3.1.0"), "title", json.str("anthropic_smoke"), "paths", json.raw(paths))
    fs.write_file(openapi_path(), spec)
    return 0
}

fn validate_schema() -> i32 {
    if fs.exists(openapi_path()) == 0 {
        export_spec()
    }
    return 0
}
