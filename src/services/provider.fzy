use core.proc;
use core.log;

fn anthropic_transport() -> i32 {
    log.info("provider.anthropic_transport", util.log_fields2("component", "provider", "phase", "transport"))
    proc.exec_timeout(200)
    return 0
}

async fn anthropic_transport_async() -> i32 {
    anthropic_transport()
    checkpoint()
    yield()
    return 0
}

fn normalize_request() -> i32 {
    log.info("provider.normalize_request", util.log_fields2("component", "provider", "phase", "normalize_request"))
    proc.exec_timeout(100)
    return 0
}

async fn normalize_request_async() -> i32 {
    normalize_request()
    checkpoint()
    return 0
}

fn normalize_response() -> i32 {
    log.info("provider.normalize_response", util.log_fields2("component", "provider", "phase", "normalize_response"))
    proc.exec_timeout(100)
    return 0
}

async fn normalize_response_async() -> i32 {
    normalize_response()
    checkpoint()
    return 0
}

fn translate_tool_calls() -> i32 {
    log.info("provider.translate_tool_calls", util.log_fields2("component", "provider", "phase", "translate_tools"))
    registry.planner_hints()
    registry.record_invocation_decision()
    proc.exec_timeout(120)
    return 0
}

async fn translate_tool_calls_async() -> i32 {
    translate_tool_calls()
    checkpoint()
    return 0
}

fn stream_completion() -> i32 {
    log.info("provider.stream_completion", util.log_fields2("component", "provider", "phase", "stream_completion"))
    runtime.events.emit_stdout_chunk()
    proc.exec_timeout(220)
    return 0
}

async fn stream_completion_async() -> i32 {
    stream_completion()
    checkpoint()
    return 0
}

fn map_provider_error() -> i32 {
    log.warn("provider.map_provider_error", util.log_fields2("component", "provider", "phase", "map_error"))
    proc.exec_timeout(120)
    return 0
}
