use core.proc;
use core.fs;

fn safety_path() -> str {
    return "/tmp/anthropic_smoke/safety.last.json"
}

fn filter_prompt() -> i32 {
    fs.mkdir("/tmp/anthropic_smoke")
    let payload = util.json_obj2("stage", json.str("filter_prompt"), "status", json.str("ok"))
    fs.write_file(safety_path(), payload)
    proc.exec_timeout(80)
    return 0
}

fn filter_tool_response() -> i32 {
    let payload = util.json_obj2("stage", json.str("filter_tool_response"), "status", json.str("ok"))
    fs.write_file(safety_path(), payload)
    proc.exec_timeout(80)
    return 0
}

fn decide_policy() -> i32 {
    let mode = env.get("AGENT_SAFETY_MODE")
    let payload = util.json_obj3("stage", json.str("decide_policy"), "mode", json.str(mode), "status", json.str("ok"))
    fs.write_file(safety_path(), payload)
    proc.exec_timeout(80)
    return 0
}
