fn boot() -> i32 {
    persistence.load_session()
    return 0
}

fn create_session() -> i32 {
    model.contracts.require_active_session()
    persistence.save_session()
    return 0
}

fn get_session() -> i32 {
    persistence.load_session()
    return 0
}

fn get_session_json() -> str {
    return persistence.load_session_json()
}

fn post_message() -> i32 {
    persistence.save_session()
    telemetry.emit_turn_latency()
    return 0
}
