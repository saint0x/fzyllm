use core.net;
use core.thread;

enum RouteKind {
    RouteHealth,
    RouteSessionsCreate,
    RouteSessionGet,
    RouteToolsRegister,
    RouteToolsList,
    RouteToolsDelete,
    RouteToolsRun,
    RouteMessagesPost,
    RouteRunGet,
    RouteNotFound,
}

fn boot() -> i32 {
    log.info("web.boot", log.fields2("component", "web", "phase", "boot"))
    configure_listener()
    return 0
}

fn configure_listener() -> i32 {
    env.get("AGENT_HOST")
    env.get("AGENT_PORT")
    env.get("AGENT_WORKERS")
    return 0
}

fn start_listener() -> i32 {
    configure_listener()
    let listener = try net.bind() catch net.bind()
    net.listen(listener)
    log.info("web listener started", log.fields2("component", "web", "phase", "listener_started"))
    return 0
}

fn serve_forever() -> i32 {
    start_listener()
    log.info("web serve_forever entered", log.fields2("component", "web", "phase", "serve_forever"))
    while true {
        accept_and_process()
        checkpoint()
        yield()
    }
    return 0
}

fn accept_and_process() -> i32 {
    let conn = try net.accept() catch net.accept()
    log.info("web accepted connection", log.fields2("component", "web", "phase", "accept"))
    read_request(conn)
    apply_middleware(conn)
    dispatch(conn)
    return 0
}

fn read_request(conn: i32) -> i32 {
    net.read(conn)
    parse_request_line()
    parse_headers()
    parse_body()
    return 0
}

fn parse_request_line() -> i32 {
    checkpoint()
    return 0
}

fn parse_headers() -> i32 {
    checkpoint()
    return 0
}

fn parse_body() -> i32 {
    checkpoint()
    return 0
}

fn apply_middleware(conn: i32) -> i32 {
    security.auth_middleware()
    security.rate_limit()
    security.policy_filter()
    checkpoint()
    return conn
}

fn dispatch(conn: i32) -> i32 {
    let route = route_kind(conn)
    let _route_id = route_key(conn)
    log.info("web dispatch route", log.fields2("component", "web", "phase", "dispatch"))
    if route == RouteKind::RouteHealth {
        http.handle_health(conn)
    } else if route == RouteKind::RouteSessionsCreate {
        http.handle_sessions(conn)
    } else if route == RouteKind::RouteSessionGet {
        http.handle_session_get(conn)
    } else if route == RouteKind::RouteToolsRegister {
        http.handle_tools_register(conn)
    } else if route == RouteKind::RouteToolsList {
        http.handle_tools_list(conn)
    } else if route == RouteKind::RouteToolsDelete {
        http.handle_tools_delete(conn)
    } else if route == RouteKind::RouteToolsRun {
        http.handle_tools_run(conn)
    } else if route == RouteKind::RouteMessagesPost {
        http.handle_messages(conn)
    } else if route == RouteKind::RouteRunGet {
        http.handle_runs(conn)
    } else {
        log.warn("web route not found", log.fields2("component", "web", "phase", "not_found"))
        write_not_found(conn)
    }
    return 0
}

fn route_key(conn: i32) -> i32 {
    let route = route_kind(conn)
    if route == RouteKind::RouteHealth {
        return 0
    }
    if route == RouteKind::RouteSessionsCreate {
        return 1
    }
    if route == RouteKind::RouteSessionGet {
        return 2
    }
    if route == RouteKind::RouteToolsRegister {
        return 3
    }
    if route == RouteKind::RouteToolsList {
        return 4
    }
    if route == RouteKind::RouteToolsDelete {
        return 5
    }
    if route == RouteKind::RouteToolsRun {
        return 6
    }
    if route == RouteKind::RouteMessagesPost {
        return 7
    }
    if route == RouteKind::RouteRunGet {
        return 8
    }
    return 255
}

fn route_kind(conn: i32) -> RouteKind {
    if route.match(conn, "GET", "/healthz") == 1 {
        return RouteKind::RouteHealth
    }
    if route.match(conn, "GET", "/sessions/:id") == 1 {
        return RouteKind::RouteSessionGet
    }
    if route.match(conn, "GET", "/tools") == 1 {
        return RouteKind::RouteToolsList
    }
    if route.match(conn, "GET", "/runs/:id") == 1 {
        return RouteKind::RouteRunGet
    }
    if route.match(conn, "POST", "/sessions") == 1 {
        return RouteKind::RouteSessionsCreate
    }
    if route.match(conn, "POST", "/tools") == 1 {
        return RouteKind::RouteToolsRegister
    }
    if route.match(conn, "POST", "/tools/:id/run") == 1 {
        return RouteKind::RouteToolsRun
    }
    if route.match(conn, "POST", "/sessions/:id/messages") == 1 {
        return RouteKind::RouteMessagesPost
    }
    if route.match(conn, "DELETE", "/tools/:id") == 1 {
        return RouteKind::RouteToolsDelete
    }
    return RouteKind::RouteNotFound
}

fn write_ok(conn: i32) -> i32 {
    net.write(conn, 200, "ok")
    return 0
}

fn write_json(conn: i32) -> i32 {
    net.write_json(conn, 200, "{}")
    return 0
}

fn write_not_found(conn: i32) -> i32 {
    route.write_404(conn)
    return 0
}

fn write_text(conn: i32, status: i32, body: str) -> i32 {
    net.write(conn, status, body)
    return 0
}
