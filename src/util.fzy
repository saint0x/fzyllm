fn json_obj2(k1: str, v1: str, k2: str, v2: str) -> str {
    let obj = map.new()
    discard map.set(obj, k1, v1)
    discard map.set(obj, k2, v2)
    return json.object(obj)
}

fn json_obj3(k1: str, v1: str, k2: str, v2: str, k3: str, v3: str) -> str {
    let obj = map.new()
    discard map.set(obj, k1, v1)
    discard map.set(obj, k2, v2)
    discard map.set(obj, k3, v3)
