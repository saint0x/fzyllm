fn json_arr1(v1: str) -> str {
    let items = list.new()
    discard list.push(items, v1)
    return json.array(items)
}

fn json_arr3(v1: str, v2: str, v3: str) -> str {
    let items = list.new()
    discard list.push(items, v1)
    discard list.push(items, v2)
    discard list.push(items, v3)
    return json.array(items)
}
